# DeplAI shared environment template
# Copy this file to .env and replace placeholder values.

# Core required
DEPLAI_SERVICE_KEY=change-me
WS_TOKEN_SECRET=change-me
SESSION_SECRET=change-me
NEXT_PUBLIC_APP_URL=http://localhost:3000
AGENTIC_LAYER_URL=http://localhost:8000

# Connector GitHub OAuth/App
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Connector + Agentic shared runtime
NEXT_PUBLIC_AGENTIC_WS_URL=ws://localhost:8000
ALLOW_GLOBAL_CLEANUP=false
DEPLAI_LOCAL_PROJECTS_ROOT=
DEPLAI_GITHUB_REPOS_ROOT=
HOST_PROJECTS_DIR=
CORS_ORIGINS=http://localhost:3000

# Connector database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=deplai

# Connector admin/workspace controls
ADMIN_EMAILS=
ADMIN_EMAIL=
ADMIN_ACCESS_KEY=
CLEANUP_SCAN_VOLUMES_ON_LOGOUT=false

# AWS runtime/cost
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
DEPLAI_FREE_TIER_EC2_TYPES=t3.micro,t2.micro
DEPLAI_ALLOW_EC2_DISABLE_FALLBACK=1
DEPLAI_EC2_INSTANCE_TYPE=

# LLM provider keys/models
ANTHROPIC_API_KEY=
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-7-sonnet-latest
CLAUDE_REPO_ANALYZER_MODEL=claude-3-5-haiku-20241022
CLAUDE_REVIEW_QUESTION_MODEL=claude-3-5-haiku-20241022
CLAUDE_INFRA_PLANNER_MODEL=
DEPLAI_CLAUDE_MAX_PIPELINE_COST_USD=3.0
DEPLAI_CLAUDE_MAX_TERRAFORM_GEN_COST_USD=1.0

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=deplai-agentic

OLLAMA_API_KEY=
OLLAMA_MODEL=qwen2.5-coder:7b

# Optional misc
PUTTYGEN_PATH=
CUSTOMIZATION_AGENT_BASE_URL=http://127.0.0.1:8010
CUSTOMIZATION_BACKEND_URL=http://127.0.0.1:8010
CONTAINER_OP_TIMEOUT=120
SCANNER_TIMEOUT_SECONDS=1800
GRYPE_TIMEOUT_SECONDS=900

# Optional Neo4j for Agentic health/KG path
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=

# Optional remediation tuning
REMEDIATION_LLM_BACKEND=auto
REMEDIATION_MAX_CONTEXT_FILES=12
REMEDIATION_MAX_PATCH_FILES=10
REMEDIATION_LLM_TIMEOUT_SECONDS=120
REMEDIATION_MAX_COMPLETION_TOKENS=2048
DEPLAI_MAX_REMEDIATION_COST_USD=1.0
