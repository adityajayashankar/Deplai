# Terraform Agent environment template

# LLM Configuration
AGENT_LLM_BACKEND=groq  # Can be one of: openai, groq, anthropic, openrouter
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=arcee-ai/trinity-large-preview:free
CLAUDE_API_KEY=your_claude_api_key
OPENAI_API_KEY=your_openai_api_key
XAI_API_KEY=your_xai_api_key

# Terraform Timeouts
DEPLAI_TERRAFORM_DEFAULT_TIMEOUT_SECONDS=900
DEPLAI_TERRAFORM_INIT_TIMEOUT_SECONDS=600
DEPLAI_TERRAFORM_PLAN_TIMEOUT_SECONDS=1800
DEPLAI_TERRAFORM_APPLY_TIMEOUT_SECONDS=3600
DEPLAI_TERRAFORM_SHOW_TIMEOUT_SECONDS=300
DEPLAI_TERRAFORM_OUTPUT_TIMEOUT_SECONDS=300
DEPLAI_TERRAFORM_UNLOCK_TIMEOUT_SECONDS=120
