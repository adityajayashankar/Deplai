# -----------------------------------------------------------------------------
# DeplAI environment template
# Copy to .env and fill values:
#   Windows (PowerShell): Copy-Item .env.template .env
#   macOS/Linux: cp .env.template .env
# Keep secrets only in .env (never commit real tokens to this template).
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# REQUIRED: OpenAI
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key

# -----------------------------------------------------------------------------
# REQUIRED: RabbitMQ (default local Docker values)
# -----------------------------------------------------------------------------
MQ_HOST=localhost
MQ_PORT=5672
MQ_USERNAME=guest
MQ_PASSWORD=guest

# -----------------------------------------------------------------------------
# REQUIRED: Redis (default local Docker values)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# OPTIONAL: Terraform/RAG helper services
# -----------------------------------------------------------------------------
HUGGING_FACE_HUB_TOKEN=
TAVILY_API_KEY=
EMBEDDING_MODEL=all-mpnet-base-v2

# -----------------------------------------------------------------------------
# OPTIONAL: AWS (needed for AWS cost estimation and GitOps deployment)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# OPTIONAL: GitHub (UI also accepts token directly at deploy time)
# -----------------------------------------------------------------------------
GITHUB_TOKEN=

# -----------------------------------------------------------------------------
# OPTIONAL: API test scripts only (api_test/)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
MISTRAL_API_KEY=
