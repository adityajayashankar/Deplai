// Jenkinsfile
pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                echo 'Checking out source code...'
                checkout scm
            }
        }

        stage('Prepare Environment') {
            steps {
                echo 'Creating .env file from template for tests...'
                sh 'cp .env.template .env'
                // NOTE: For a production pipeline, secrets (API keys, etc.) should be injected securely 
                // using the Jenkins Credentials plugin, not from a file. This approach is suitable 
                // for local testing as described in the project documentation.
            }
        }

        stage('Run Tests in Parallel') {
            failFast true
            parallel {

                stage('Test with Docker Compose') {
                    agent any // Requires an agent with docker, docker-compose, and python3
                    environment {
                        // Use a unique project name for Docker Compose to avoid conflicts
                        COMPOSE_PROJECT_NAME = "deplai-ci-${env.BUILD_NUMBER}"
                        // Add the installation directory for docker-compose to the PATH
                        PATH = "/usr/local/bin:${env.PATH}"
                        // Define the path for the virtual environment
                        VENV_PATH = "${env.WORKSPACE}/.venv-dc-test"
                        // Tell the test script to connect to the host machine's Docker instance
                        MQ_HOST = 'host.docker.internal'
                    }
                    steps {
                        script {
                            try {
                                echo "--- Building and starting services with Docker Compose ---"
                                sh "sudo docker-compose up -d --build"

                                echo "--- Setting up Python test environment on the Jenkins agent ---"
                                sh "python3 -m venv ${VENV_PATH}"
                                // Use the pip from the venv directly, no 'source' needed
                                sh "${VENV_PATH}/bin/pip install -r requirements.txt"
                                sh "${VENV_PATH}/bin/pip install pytest pika"
                                
                                echo "--- Waiting for services in Docker containers to initialize ---"
                                sleep 25

                                echo "--- Running integration tests ---"
                                // Use the pytest from the venv directly
                                sh "${VENV_PATH}/bin/pytest -v tests/test_integration.py"

                            } finally {
                                echo "--- Tearing down Docker Compose environment ---"
                                sh "sudo docker-compose down --volumes --remove-orphans"
                            }
                        }
                    }
                }

                stage('Test with Manual Setup') {
                    agent any // Requires an agent with docker and python3
                    environment {
                        VENV_PATH = "${env.WORKSPACE}/.venv-manual-test"
                        // Add the virtual environment's bin to the PATH for all 'sh' steps in this stage
                        PATH = "${VENV_PATH}/bin:${env.PATH}"
                        // Tell the test script to connect to the host machine's Docker instance
                        MQ_HOST = 'host.docker.internal'
                    }
                    steps {
                        script {
                            // Use unique names for containers to avoid conflicts
                            def rabbitContainer = "rabbitmq-ci-${env.BUILD_NUMBER}"
                            def redisContainer = "redis-ci-${env.BUILD_NUMBER}"
                            
                            try {
                                echo "--- Starting dependency containers (RabbitMQ, Redis) ---"
                                sh "sudo docker run -d --name ${rabbitContainer} -p 5672:5672 -p 15672:15672 -e RABBITMQ_DEFAULT_USER=guest -e RABBITMQ_DEFAULT_PASS=guest rabbitmq:3-management"
                                sh "sudo docker run -d --name ${redisContainer} -p 6379:6379 redis:latest"
                                
                                echo "--- Waiting for dependency containers to initialize ---"
                                sleep 15

                                echo "--- Setting up Python environment ---"
                                sh "python3 -m venv ${VENV_PATH}"
                                sh "pip install --upgrade pip"
                                sh "pip install -r requirements.txt"
                                sh "pip install pytest pika"

                                echo "--- Running main backend service in the background ---"
                                // The .env file is already present in the workspace
                                sh 'nohup python3 main.py > main-service.log 2>&1 & echo $! > main-service.pid'
                                
                                echo "--- Waiting for backend service to initialize its threads ---"
                                sleep 20

                                echo "--- Running integration tests ---"
                                sh 'pytest -v tests/test_integration.py'

                            } finally {
                                echo "--- Tearing down manual environment ---"
                                sh 'if [ -f main-service.pid ]; then kill $(cat main-service.pid) || true; fi'
                                sh "sudo docker stop ${rabbitContainer} && sudo docker rm ${rabbitContainer} || true"
                                sh "sudo docker stop ${redisContainer} && sudo docker rm ${redisContainer} || true"
                                sh 'rm -f *.pid *.log'
                            }
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            echo 'Test run finished. Cleaning up workspace.'
            // cleanWs() will remove the entire workspace, including virtual envs, etc.
            cleanWs()
        }
    }
} 