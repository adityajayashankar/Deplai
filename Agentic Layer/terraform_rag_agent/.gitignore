# Python generated files
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# Virtual environments
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# Environment variables
.env
.env.*
!.env.template
!.env.example

# Terraform state and configuration
.terraform/
*.tfstate
*.tfstate.*.backup
.terraform.lock.hcl
crash.log
override.tf
override.tf.json
