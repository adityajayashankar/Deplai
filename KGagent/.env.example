# KG Agent Environment Template

# Neo4j Knowledge Graph
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=kgvtwo

# Optional: Qdrant cloud/local
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=vuln_kg_evidence_v1
QDRANT_PATH=data/qdrant
QDRANT_TOP_K=20
QDRANT_TEXT_FIELD=text

# Embeddings
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DEVICE=cpu
GRAPHRAG_EMBED_BATCH_SIZE=64

# Agent retrieval controls
AGENT_GRAPHRAG_TOP_K=20
AGENT_GRAPHRAG_MAX_HOPS=2
GRAPHRAG_USE_VECTOR=0
AGENT_GRAPHRAG_USE_VECTOR=0
GRAPHRAG_DATASET_GROUP_SIZE=10
GRAPHRAG_MIN_COOCCUR_PER_CVE=2
GRAPHRAG_GRAPH_WEIGHT_HOP1=0.88
GRAPHRAG_GRAPH_WEIGHT_HOP2=0.55

# Optional: indexer quotas
GRAPHRAG_ENABLE_DATASET=1
GRAPHRAG_ENABLE_COOC=1
GRAPHRAG_ENABLE_CORR=1
GRAPHRAG_ENABLE_KG_EDGE_CHUNKS=0
GRAPHRAG_MAX_REL_PER_CVE=4
GRAPHRAG_MIN_CORR_SCORE=0.60
GRAPHRAG_DATASET_QUOTA=150000
GRAPHRAG_COOC_QUOTA=100000
GRAPHRAG_CORR_QUOTA=50000
GRAPHRAG_MAX_CORR_ROWS=15000
GRAPHRAG_MAX_COOC_ROWS=70000
GRAPHRAG_MAX_TOTAL_CHUNKS=300000

# LLM backend (configure at least one)
GROQ_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_HOST=http://localhost:11434
