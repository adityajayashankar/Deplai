# KGagent environment template
# Copy this file to KGagent/.env and fill secrets.

# Neo4j
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=kgvtwo
APP_ENV=development

# LLM providers
GROQ_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-oss-120b
OPENROUTER_APP_NAME=deplai-agentic
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_API_KEY=

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_PATH=
QDRANT_COLLECTION=vuln_kg_evidence_v1
QDRANT_TEXT_FIELD=chunk_text
QDRANT_TOP_K=10

# GraphRAG and embedding
GRAPHRAG_USE_VECTOR=0
GRAPHRAG_CHUNK_SIZE=900
GRAPHRAG_CHUNK_OVERLAP=120
GRAPHRAG_EMBED_BATCH_SIZE=512
GRAPHRAG_UPSERT_BATCH_SIZE=100
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DEVICE=cpu
KG_BATCH_SIZE=2000
