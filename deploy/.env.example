# Copy to deploy/.env, set every placeholder, then keep deploy/.env off Git.
# Start with:
# docker compose --env-file deploy/.env -f docker-compose.production.yml up -d --build

# Public EC2 IPv4 address. This deployment intentionally serves HTTP only.
APP_DOMAIN=13.48.163.201
NEXT_PUBLIC_APP_URL=http://13.48.163.201
# Caddy proxies this route to FastAPI and handles WebSocket upgrades.
NEXT_PUBLIC_AGENTIC_WS_URL=ws://13.48.163.201/agentic
CORS_ORIGINS=http://13.48.163.201

# Docker image tags. Pin these to approved digests before a regulated launch.
CADDY_IMAGE=caddy:2.8.4-alpine
MYSQL_IMAGE=mysql:8.4
NEO4J_IMAGE=neo4j:5-community
QDRANT_IMAGE=qdrant/qdrant:v1.13.6

# Required shared secrets. Generate each independently, for example:
# openssl rand -hex 32
DEPLAI_SERVICE_KEY=replace-with-64-random-hex-characters
WS_TOKEN_SECRET=replace-with-a-different-64-random-hex-characters
SESSION_SECRET=replace-with-a-different-64-random-hex-characters
ADMIN_EMAILS=admin@example.com
ADMIN_ACCESS_KEY=replace-with-a-different-64-random-hex-characters
ALLOW_GLOBAL_CLEANUP=false

# MySQL is internal-only. MYSQL_PASSWORD and MYSQL_ROOT_PASSWORD must differ.
MYSQL_DATABASE=deplai
MYSQL_USER=deplai
MYSQL_PASSWORD=replace-with-a-strong-database-password
MYSQL_ROOT_PASSWORD=replace-with-a-different-strong-root-password

# GitHub OAuth App and GitHub App. Supply the private key as a single-line
# base64 string: base64 -w0 github-app-private-key.pem
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Required by the Agentic Layer Docker SDK. On the Linux host run:
# stat -c '%g' /var/run/docker.sock
DOCKER_GID=998

# Internal-only graph services required by this deployment topology.
NEO4J_PASSWORD=replace-with-a-strong-neo4j-password

# Cloud integrations. Leave AWS values empty only when AWS apply/runtime
# functionality is intentionally disabled.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1

# Configure one or more model providers used by Agentic/Customization services.
ANTHROPIC_API_KEY=
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-7-sonnet-latest
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=deplai-agentic
OLLAMA_API_KEY=
OLLAMA_MODEL=qwen2.5-coder:7b

# Scan, remediation, and Terraform limits.
SCANNER_TIMEOUT_SECONDS=1800
GRYPE_TIMEOUT_SECONDS=900
CONTAINER_OP_TIMEOUT=120
REMEDIATION_MAX_COMPLETION_TOKENS=2048
DEPLAI_MAX_REMEDIATION_COST_USD=1.0
DEPLAI_CLAUDE_MAX_PIPELINE_COST_USD=3.0
IAC_WORKSPACE_TTL_HOURS=24
